// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model OptionSet {
  id           String                @id @default(cuid())
  shop         String
  title        String
  internalName String?
  isActive     Boolean               @default(true)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  options      Option[]
  assignments  OptionSetAssignment[]
}

model Option {
  id          String    @id @default(cuid())
  optionSetId String
  optionSet   OptionSet @relation(fields: [optionSetId], references: [id], onDelete: Cascade)

  name     String
  label    String
  type     String // TEXT, TEXTAREA, NUMBER, DROPDOWN, RADIO, CHECKBOX, BUTTONS, COLOR_SWATCH, IMAGE_SWATCH, FILE_UPLOAD, DATE, TIME, PRODUCT_PICKER, VARIANT_PICKER, QUANTITY

  helpText String?
  tooltip  String?
  required Boolean @default(false)

  settings String // JSON string for defaults, placeholders, limits, conditional logic, pricing rules

  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OptionSetAssignment {
  id          String    @id @default(cuid())
  optionSetId String
  optionSet   OptionSet @relation(fields: [optionSetId], references: [id], onDelete: Cascade)

  type        String // ALL_PRODUCTS, PRODUCT, COLLECTION, TAG, VENDOR, TYPE
  targetId    String? // ID of the product, collection, tag name, etc.
  isExclusion Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderCustomization {
  id                String  @id @default(cuid())
  shop              String
  shopifyOrderId    String?
  shopifyLineItemId String?

  optionsData String // JSON string containing the selected options, values, price additions

  status    String   @default("PENDING") // PENDING, ORDERED, IN_PRODUCTION, COMPLETED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CustomizableProduct {
  id               String                @id @default(cuid())
  shop             String
  shopifyProductId String
  title            String
  isActive         Boolean               @default(true)
  mockupImageUrl   String
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  options          CustomizationOption[]
  submissions      DesignSubmission[]
}

model CustomizationOption {
  id                    String              @id @default(cuid())
  customizableProductId String
  product               CustomizableProduct @relation(fields: [customizableProductId], references: [id], onDelete: Cascade)
  type                  String
  label                 String
  required              Boolean             @default(false)
  config                String
  printAreaX            Float               @default(0)
  printAreaY            Float               @default(0)
  printAreaWidth        Float               @default(200)
  printAreaHeight       Float               @default(200)
  sortOrder             Int                 @default(0)
}

model DesignSubmission {
  id                    String              @id @default(cuid())
  shop                  String
  customizableProductId String
  product               CustomizableProduct @relation(fields: [customizableProductId], references: [id], onDelete: Cascade)
  shopifyOrderId        String?
  shopifyLineItemId     String?
  designData            String
  previewImageUrl       String
  hiResImageUrl         String?
  customerNote          String?
  status                String              @default("PENDING")
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
}

model AppSetting {
  id        String   @id @default(cuid())
  shop      String   @unique
  settings  String   // JSON string containing all user settings
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
