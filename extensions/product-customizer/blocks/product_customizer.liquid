<div
  id="pxl-product-customizer-root"
  class="pxl-customizer-container"
  style="display: none;"
  data-product-id="{{ product.id }}"
  data-variant-id="{{ product.selected_or_first_available_variant.id }}"
  data-base-price="{{ product.selected_or_first_available_variant.price }}"
  data-currency-symbol="{{ cart.currency.symbol | default: '$' }}"
  data-shop="{{ shop.permanent_domain | default: shop.domain }}"
>
  <!-- Sleek Header -->
  <div class="pxl-customizer-header">
    <div class="pxl-header-badge">✨ Interactive Studio</div>
    <h3 class="pxl-customizer-title">{{ block.settings.heading | default: "Personalize Your Product" }}</h3>
    <p class="pxl-customizer-subtitle">Design your custom product in real time before adding to cart.</p>
  </div>

  <div class="pxl-customizer-layout">
    <!-- Canvas Column (Always prominent & stacked cleanly on narrow screens) -->
    <div class="pxl-canvas-column" id="pxl-canvas-wrapper">
      <div class="pxl-canvas-studio">
        <div class="pxl-canvas-container-inner">
          <canvas id="pxl-customizer-canvas"></canvas>
        </div>
      </div>
      
      <!-- Canvas Actions Bar -->
      <div class="pxl-canvas-toolbar">
        <span class="pxl-canvas-tip">💡 Tip: Drag & resize layers directly on the preview</span>
        <div class="pxl-canvas-actions">
          <button type="button" id="pxl-btn-delete-selected" class="pxl-toolbar-btn" disabled title="Delete selected element">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
            <span>Delete</span>
          </button>
          <button type="button" id="pxl-btn-reset-canvas" class="pxl-toolbar-btn" title="Reset design">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"/></svg>
            <span>Reset</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Controls Column -->
    <div class="pxl-controls-column">
      <div id="pxl-options-list" class="pxl-options-list">
        <!-- Options rendered dynamically -->
      </div>

      <div id="pxl-error-banner" class="pxl-error-banner" style="display: none;"></div>
      <div id="pxl-success-banner" class="pxl-success-banner" style="display: none;"></div>

      <div id="pxl-price-summary" class="pxl-price-summary">
        <div class="pxl-price-row">
          <span>Base Price</span>
          <span id="pxl-base-price">{{ product.selected_or_first_available_variant.price | money }}</span>
        </div>
        <div class="pxl-price-row pxl-fee-row" id="pxl-fee-row" style="display: none;">
          <span>Customization Fee</span>
          <span id="pxl-custom-fee">+$0.00</span>
        </div>
        <div class="pxl-price-divider"></div>
        <div class="pxl-price-row pxl-total-row">
          <span>Total Price</span>
          <span id="pxl-total-price">{{ product.selected_or_first_available_variant.price | money }}</span>
        </div>
      </div>

      <div class="pxl-actions">
        <button id="pxl-add-to-cart-btn" class="pxl-btn-primary">
          <svg class="pxl-btn-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
          <span class="pxl-btn-text">{{ block.settings.button_label | default: "Add Customized to Cart" }}</span>
        </button>
      </div>
    </div>
  </div>
</div>

<style>
  /* Base Container & Typography */
  .pxl-customizer-container {
    container-type: inline-size;
    display: flex;
    flex-direction: column;
    margin: 28px 0;
    padding: 24px;
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.08);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    color: #0f172a;
    box-sizing: border-box;
    -webkit-font-smoothing: antialiased;
  }

  .pxl-customizer-header {
    margin-bottom: 24px;
    border-bottom: 1px solid #f1f5f9;
    padding-bottom: 16px;
  }

  .pxl-header-badge {
    display: inline-flex;
    align-items: center;
    padding: 4px 10px;
    background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
    color: #15803d;
    font-size: 12px;
    font-weight: 700;
    border-radius: 20px;
    margin-bottom: 8px;
    letter-spacing: 0.3px;
    border: 1px solid #bbf7d0;
  }

  .pxl-customizer-title {
    margin: 0 0 6px 0;
    font-size: 22px;
    font-weight: 800;
    color: #0f172a;
    letter-spacing: -0.5px;
  }

  .pxl-customizer-subtitle {
    margin: 0;
    font-size: 14px;
    color: #64748b;
    line-height: 1.5;
  }

  /* Responsive Grid Layout */
  .pxl-customizer-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 28px;
    align-items: start;
  }

  @container (min-width: 640px) {
    .pxl-customizer-layout {
      grid-template-columns: 1.1fr 0.9fr;
      gap: 32px;
    }
  }

  /* Canvas Studio Column */
  .pxl-canvas-column {
    display: flex;
    flex-direction: column;
    width: 100%;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: inset 0 2px 4px rgba(0, 0, 0, 0.02);
  }

  .pxl-canvas-studio {
    position: relative;
    width: 100%;
    padding: 20px 16px;
    display: flex;
    justify-content: center;
    align-items: center;
    background-image: radial-gradient(#cbd5e1 1px, transparent 1px);
    background-size: 16px 16px;
    min-height: 320px;
  }

  .pxl-canvas-container-inner {
    position: relative;
    display: flex;
    justify-content: center;
    box-shadow: 0 12px 24px -6px rgba(0, 0, 0, 0.12), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
    border-radius: 8px;
    overflow: hidden;
    background: #ffffff;
  }

  /* Canvas Toolbar */
  .pxl-canvas-toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
    padding: 12px 16px;
    background: #ffffff;
    border-top: 1px solid #e2e8f0;
  }

  .pxl-canvas-tip {
    font-size: 12px;
    color: #64748b;
    font-weight: 500;
  }

  .pxl-canvas-actions {
    display: flex;
    gap: 8px;
  }

  .pxl-toolbar-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    background: #f1f5f9;
    color: #334155;
    border: 1px solid #cbd5e1;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .pxl-toolbar-btn:hover:not(:disabled) {
    background: #e2e8f0;
    color: #0f172a;
  }

  .pxl-toolbar-btn:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  #pxl-btn-delete-selected:not(:disabled) {
    background: #fef2f2;
    border-color: #fecaca;
    color: #dc2626;
  }

  #pxl-btn-delete-selected:not(:disabled):hover {
    background: #fee2e2;
  }

  /* Controls Column */
  .pxl-controls-column {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .pxl-options-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .pxl-option-card {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .pxl-option-card:focus-within {
    border-color: #3b82f6;
    box-shadow: 0 4px 12px rgba(59, 130, 246, 0.08);
  }

  .pxl-option-label {
    font-size: 14px;
    font-weight: 700;
    color: #0f172a;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .pxl-required-badge {
    color: #dc2626;
    font-size: 12px;
    font-weight: 600;
    background: #fef2f2;
    padding: 2px 8px;
    border-radius: 12px;
  }

  .pxl-input-group {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  /* Styled Inputs */
  .pxl-text-input,
  .pxl-select-input {
    width: 100%;
    padding: 11px 14px;
    border: 1px solid #cbd5e1;
    border-radius: 8px;
    font-size: 14px;
    background: #f8fafc;
    color: #0f172a;
    box-sizing: border-box;
    outline: none;
    transition: all 0.15s ease;
  }

  .pxl-text-input:focus,
  .pxl-select-input:focus {
    background: #ffffff;
    border-color: #3b82f6;
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15);
  }

  /* Drag & Drop File Upload Dropzone */
  .pxl-upload-dropzone {
    position: relative;
    border: 2px dashed #cbd5e1;
    border-radius: 10px;
    padding: 20px 16px;
    text-align: center;
    background: #f8fafc;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .pxl-upload-dropzone:hover {
    border-color: #3b82f6;
    background: #eff6ff;
  }

  .pxl-upload-icon {
    font-size: 24px;
    margin-bottom: 6px;
  }

  .pxl-upload-text {
    font-size: 13px;
    color: #334155;
    margin-bottom: 2px;
  }

  .pxl-upload-sub {
    font-size: 11px;
    color: #64748b;
  }

  .pxl-file-input-hidden {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
    width: 100%;
    height: 100%;
  }

  .pxl-file-pill {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 12px;
    background: #eff6ff;
    border: 1px solid #bfdbfe;
    border-radius: 8px;
    font-size: 13px;
    color: #1e40af;
    margin-top: 8px;
  }

  /* Color Picker Swatches */
  .pxl-swatch-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .pxl-swatch-btn {
    position: relative;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 3px solid #ffffff;
    box-shadow: 0 0 0 1px #cbd5e1;
    cursor: pointer;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pxl-swatch-btn:hover {
    transform: scale(1.12);
    box-shadow: 0 0 0 2px #64748b;
  }

  .pxl-swatch-btn.active {
    box-shadow: 0 0 0 2.5px #0f172a;
    transform: scale(1.12);
  }

  .pxl-swatch-btn.active::after {
    content: "✓";
    color: #ffffff;
    font-size: 16px;
    font-weight: 800;
    text-shadow: 0 1px 2px rgba(0,0,0,0.6);
  }

  /* Banners & Actions */
  .pxl-error-banner {
    padding: 14px;
    background-color: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: 10px;
    color: #b91c1c;
    font-size: 13px;
    font-weight: 600;
  }

  .pxl-success-banner {
    padding: 14px;
    background-color: #f0fdf4;
    border: 1px solid #bbf7d0;
    border-radius: 10px;
    color: #15803d;
    font-size: 13px;
    font-weight: 600;
  }

  .pxl-price-summary {
    background: #f8fafc;
    border: 1px solid #cbd5e1;
    border-radius: 10px;
    padding: 14px 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    font-size: 14px;
    margin-top: 4px;
  }

  .pxl-price-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: #475569;
  }

  .pxl-total-row {
    font-weight: 800;
    font-size: 16px;
    color: #0f172a;
  }

  .pxl-price-divider {
    height: 1px;
    background: #e2e8f0;
    margin: 4px 0;
  }

  .pxl-actions {
    margin-top: 6px;
  }

  .pxl-btn-primary {
    width: 100%;
    padding: 16px 24px;
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
    color: #ffffff;
    border: none;
    border-radius: 12px;
    font-size: 16px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s ease;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
    box-shadow: 0 4px 14px rgba(15, 23, 42, 0.25);
  }

  .pxl-btn-primary:hover:not(:disabled) {
    background: linear-gradient(135deg, #008060 0%, #006e52 100%);
    box-shadow: 0 6px 20px rgba(0, 128, 96, 0.35);
    transform: translateY(-1px);
  }

  .pxl-btn-primary:disabled {
    background: #94a3b8;
    box-shadow: none;
    cursor: not-allowed;
    transform: none;
  }
</style>

<script src="https://cdnjs.cloudflare.com/ajax/libs/fabric.js/5.3.1/fabric.min.js"></script>
<script>
  (function () {
    const root = document.getElementById("pxl-product-customizer-root");
    if (!root) return;

    const productId = root.getAttribute("data-product-id");
    const variantId = root.getAttribute("data-variant-id");
    const shop = root.getAttribute("data-shop");

    if (!productId) return;

    let canvas = null;
    let customizableProduct = null;
    let optionValues = {};
    let logicalWidth = 500;
    let logicalHeight = 500;

    const deleteBtn = document.getElementById("pxl-btn-delete-selected");
    const resetBtn = document.getElementById("pxl-btn-reset-canvas");

    function initCustomizer() {
      fetch(`/apps/customizer/config?productId=${productId}&shop=${shop || ""}`)
        .then((res) => res.json())
        .then((data) => {
          if (!data || !data.active || !data.customizableProduct) {
            root.style.display = "none";
            return;
          }

          customizableProduct = data.customizableProduct;
          root.style.display = "flex";
          setupCanvas();
          renderControls();
          updatePriceDisplay();
        })
        .catch((err) => {
          console.error("Failed to load Product Customizer config:", err);
          root.style.display = "none";
        });

      // Listen for Shopify variant selection changes on the page
      document.addEventListener("change", (e) => {
        const target = e.target;
        if (target && (target.name === "id" || target.getAttribute("name") === "id")) {
          const newVariantId = target.value;
          if (newVariantId && root.getAttribute("data-variant-id") !== newVariantId) {
            root.setAttribute("data-variant-id", newVariantId);
          }
        }
      });
    }

    function updatePriceDisplay() {
      if (!customizableProduct || !customizableProduct.options) return;
      const basePriceCents = Number(root.getAttribute("data-base-price")) || 0;
      const currency = root.getAttribute("data-currency-symbol") || "$";

      let customFeeCents = 0;
      customizableProduct.options.forEach((opt) => {
        if (optionValues[opt.id]) {
          const fee = Number(opt.config.priceAddon || opt.config.price || 0);
          if (fee > 0) {
            customFeeCents += Math.round(fee * 100);
          }
        }
      });

      const basePriceEl = document.getElementById("pxl-base-price");
      const feeRowEl = document.getElementById("pxl-fee-row");
      const customFeeEl = document.getElementById("pxl-custom-fee");
      const totalPriceEl = document.getElementById("pxl-total-price");

      if (basePriceEl) basePriceEl.textContent = `${currency}${(basePriceCents / 100).toFixed(2)}`;
      if (customFeeEl && feeRowEl) {
        if (customFeeCents > 0) {
          customFeeEl.textContent = `+${currency}${(customFeeCents / 100).toFixed(2)}`;
          feeRowEl.style.display = "flex";
        } else {
          feeRowEl.style.display = "none";
        }
      }
      if (totalPriceEl) {
        totalPriceEl.textContent = `${currency}${((basePriceCents + customFeeCents) / 100).toFixed(2)}`;
      }
    }

    function setupCanvas() {
      const canvasEl = document.getElementById("pxl-customizer-canvas");
      const studio = document.querySelector(".pxl-canvas-studio");
      
      const availableWidth = Math.min(studio.clientWidth - 32, 520);
      logicalWidth = availableWidth > 280 ? availableWidth : 340;
      logicalHeight = logicalWidth;

      canvas = new fabric.Canvas(canvasEl, {
        width: logicalWidth,
        height: logicalHeight,
        selection: true,
        preserveObjectStacking: true,
      });

      // Customize selection control handles for modern look
      fabric.Object.prototype.set({
        transparentCorners: false,
        cornerColor: "#3b82f6",
        cornerStrokeColor: "#ffffff",
        borderColor: "#3b82f6",
        cornerSize: 11,
        padding: 6,
        cornerStyle: "circle",
      });

      if (customizableProduct.mockupImageUrl) {
        loadBackgroundMockup();
      }

      window.addEventListener("resize", handleCanvasResize);

      // Selection state listeners for Delete button
      canvas.on("selection:created", () => { deleteBtn.disabled = false; });
      canvas.on("selection:updated", () => { deleteBtn.disabled = false; });
      canvas.on("selection:cleared", () => { deleteBtn.disabled = true; });

      if (deleteBtn) {
        deleteBtn.addEventListener("click", () => {
          const active = canvas.getActiveObject();
          if (active) {
            if (active.optId) {
              // Clear option value if linked
              optionValues[active.optId] = "";
              const textInput = document.querySelector(`[data-opt-id="${active.optId}"] input[type="text"]`);
              if (textInput) textInput.value = "";
            }
            canvas.remove(active);
            canvas.discardActiveObject();
            canvas.renderAll();
          }
        });
      }

      if (resetBtn) {
        resetBtn.addEventListener("click", () => {
          if (confirm("Reset your current design elements?")) {
            canvas.getObjects().forEach((obj) => {
              canvas.remove(obj);
            });
            optionValues = {};
            document.querySelectorAll(".pxl-text-input").forEach((inp) => (inp.value = ""));
            document.querySelectorAll(".pxl-swatch-btn").forEach((btn) => btn.classList.remove("active"));
            document.querySelectorAll(".pxl-file-pill").forEach((pill) => pill.remove());
            canvas.discardActiveObject();
            canvas.renderAll();
          }
        });
      }
    }

    function loadBackgroundMockup() {
      fabric.Image.fromURL(
        customizableProduct.mockupImageUrl,
        function (img) {
          const scale = Math.min(
            logicalWidth / img.width,
            logicalHeight / img.height
          );
          img.set({
            scaleX: scale,
            scaleY: scale,
            left: (logicalWidth - img.width * scale) / 2,
            top: (logicalHeight - img.height * scale) / 2,
            selectable: false,
            evented: false,
          });
          canvas.setBackgroundImage(img, canvas.renderAll.bind(canvas));
        },
        { crossOrigin: "anonymous" }
      );
    }

    function handleCanvasResize() {
      if (!canvas) return;
      const studio = document.querySelector(".pxl-canvas-studio");
      const newWidth = Math.min(studio.clientWidth - 32, logicalWidth);
      if (newWidth > 120) {
        const zoom = newWidth / logicalWidth;
        canvas.setDimensions({
          width: logicalWidth * zoom,
          height: logicalHeight * zoom,
        });
        canvas.setZoom(zoom);
        canvas.renderAll();
      }
    }

    function renderControls() {
      const optionsListEl = document.getElementById("pxl-options-list");
      optionsListEl.innerHTML = "";

      if (!customizableProduct.options || customizableProduct.options.length === 0) {
        optionsListEl.innerHTML = '<p style="color:#64748b;font-size:14px;">No customizable options configured for this product.</p>';
        return;
      }

      customizableProduct.options.forEach((opt) => {
        const card = document.createElement("div");
        card.className = "pxl-option-card";
        card.setAttribute("data-opt-id", opt.id);

        const currency = root.getAttribute("data-currency-symbol") || "$";
        const fee = Number(opt.config.priceAddon || opt.config.price || 0);
        const feeBadge = fee > 0 ? `<span style="background:#f1f5f9;color:#0f172a;padding:2px 8px;border-radius:6px;font-size:12px;font-weight:700;">+${currency}${fee.toFixed(2)}</span>` : "";

        const labelEl = document.createElement("div");
        labelEl.className = "pxl-option-label";
        labelEl.innerHTML = `<span>${opt.label} ${feeBadge}</span>${opt.required ? '<span class="pxl-required-badge">Required</span>' : ''}`;
        card.appendChild(labelEl);

        const inputGroup = document.createElement("div");
        inputGroup.className = "pxl-input-group";

        if (opt.type === "TEXT") {
          const fontChoices = opt.config.fonts || ["Arial", "Outfit", "Courier New", "Georgia", "Verdana"];
          if (fontChoices.length > 0) {
            const selectFont = document.createElement("select");
            selectFont.className = "pxl-select-input";
            fontChoices.forEach((font) => {
              const option = document.createElement("option");
              option.value = font;
              option.textContent = `Font: ${font}`;
              selectFont.appendChild(option);
            });
            selectFont.addEventListener("change", (e) => updateTextObject(opt, { fontFamily: e.target.value }));
            inputGroup.appendChild(selectFont);
          }

          const textInput = document.createElement("input");
          textInput.type = "text";
          textInput.className = "pxl-text-input";
          textInput.placeholder = "Type your text here...";
          if (opt.config.maxChars) textInput.maxLength = opt.config.maxChars;

          textInput.addEventListener("input", (e) => {
            const val = e.target.value;
            optionValues[opt.id] = val;
            updateTextObject(opt, { text: val });
          });
          inputGroup.appendChild(textInput);
        } else if (opt.type === "IMAGE_UPLOAD") {
          const dropzone = document.createElement("div");
          dropzone.className = "pxl-upload-dropzone";
          dropzone.innerHTML = `
            <div class="pxl-upload-icon">📁</div>
            <div class="pxl-upload-text"><strong>Click to select image</strong> or drag & drop</div>
            <div class="pxl-upload-sub">PNG, JPG, WEBP (Max ${opt.config.maxFileSizeMB || 10}MB)</div>
            <input type="file" accept="image/*" class="pxl-file-input-hidden" />
          `;

          const fileInput = dropzone.querySelector("input");
          fileInput.addEventListener("change", (e) => {
            const file = e.target.files[0];
            if (!file) return;

            const maxMB = opt.config.maxFileSizeMB || 10;
            if (file.size > maxMB * 1024 * 1024) {
              showError(`Image exceeds maximum allowed size (${maxMB} MB).`);
              return;
            }

            hideError();
            const reader = new FileReader();
            reader.onload = function (event) {
              const dataUrl = event.target.result;
              optionValues[opt.id] = dataUrl;
              updateImageObject(opt, dataUrl);

              // Update pill UI
              let pill = card.querySelector(".pxl-file-pill");
              if (!pill) {
                pill = document.createElement("div");
                pill.className = "pxl-file-pill";
                card.appendChild(pill);
              }
              pill.innerHTML = `<span>🖼️ ${file.name.slice(0, 20)}...</span> <strong style="cursor:pointer;" title="Remove">✕</strong>`;
              pill.querySelector("strong").addEventListener("click", (ev) => {
                ev.stopPropagation();
                fileInput.value = "";
                optionValues[opt.id] = "";
                const obj = findObjectByOptId(opt.id);
                if (obj) canvas.remove(obj);
                canvas.renderAll();
                pill.remove();
                updatePriceDisplay();
              });
            };
            reader.readAsDataURL(file);
          });

          inputGroup.appendChild(dropzone);
        } else if (opt.type === "COLOR_PICKER") {
          const colors = opt.config.colors || ["#0f172a", "#ef4444", "#22c55e", "#3b82f6", "#eab308", "#ec4899", "#ffffff"];
          const swatchList = document.createElement("div");
          swatchList.className = "pxl-swatch-list";

          colors.forEach((hex) => {
            const btn = document.createElement("button");
            btn.type = "button";
            btn.className = "pxl-swatch-btn";
            btn.style.backgroundColor = hex;
            btn.title = `Color ${hex}`;
            btn.addEventListener("click", () => {
              swatchList.querySelectorAll(".pxl-swatch-btn").forEach((b) => b.classList.remove("active"));
              btn.classList.add("active");
              optionValues[opt.id] = hex;
              updateColorObject(opt, hex);
            });
            swatchList.appendChild(btn);
          });
          inputGroup.appendChild(swatchList);
        } else if (opt.type === "DROPDOWN") {
          const choices = opt.config.choices || ["Standard Option 1", "Standard Option 2"];
          const select = document.createElement("select");
          select.className = "pxl-select-input";

          const defaultOpt = document.createElement("option");
          defaultOpt.value = "";
          defaultOpt.textContent = "-- Choose an option --";
          select.appendChild(defaultOpt);

          choices.forEach((choice) => {
            const option = document.createElement("option");
            option.value = choice;
            option.textContent = choice;
            select.appendChild(option);
          });

          select.addEventListener("change", (e) => {
            const val = e.target.value;
            optionValues[opt.id] = val;
            updateDropdownObject(opt, val);
          });
          inputGroup.appendChild(select);
        }

        card.appendChild(inputGroup);
        optionsListEl.appendChild(card);
      });
    }

    function findObjectByOptId(optId) {
      if (!canvas) return null;
      return canvas.getObjects().find((o) => o.optId === optId);
    }

    function updateTextObject(opt, updates) {
      if (!canvas) return;
      let obj = findObjectByOptId(opt.id);

      if (updates.text === "") {
        if (obj) canvas.remove(obj);
        canvas.renderAll();
        return;
      }

      if (obj) {
        if (updates.text !== undefined) obj.set("text", updates.text);
        if (updates.fontFamily !== undefined) obj.set("fontFamily", updates.fontFamily);
        if (updates.fill !== undefined) obj.set("fill", updates.fill);
      } else if (updates.text) {
        const selectEl = document.querySelector(`[data-opt-id="${opt.id}"] select`);
        const initialFont = selectEl ? selectEl.value : (opt.config.fonts?.[0] || "Arial");
        
        obj = new fabric.IText(updates.text, {
          left: opt.printAreaX || (logicalWidth * 0.2),
          top: opt.printAreaY || (logicalHeight * 0.4),
          width: opt.printAreaWidth || (logicalWidth * 0.6),
          fontSize: opt.config.defaultFontSize || 28,
          fontFamily: initialFont,
          fill: opt.config.defaultColor || "#0f172a",
          editable: true,
        });
        obj.optId = opt.id;
        canvas.add(obj);
        canvas.setActiveObject(obj);
      }
      canvas.renderAll();
      updatePriceDisplay();
    }

    function updateImageObject(opt, dataUrl) {
      if (!canvas) return;
      let oldObj = findObjectByOptId(opt.id);
      if (oldObj) canvas.remove(oldObj);

      fabric.Image.fromURL(
        dataUrl,
        function (img) {
          const targetW = opt.printAreaWidth || (logicalWidth * 0.45);
          const targetH = opt.printAreaHeight || (logicalHeight * 0.45);
          const scale = Math.min(targetW / img.width, targetH / img.height);

          img.set({
            left: opt.printAreaX || (logicalWidth * 0.28),
            top: opt.printAreaY || (logicalHeight * 0.28),
            scaleX: scale,
            scaleY: scale,
          });
          img.optId = opt.id;
          canvas.add(img);
          canvas.setActiveObject(img);
          canvas.renderAll();
          updatePriceDisplay();
        },
        { crossOrigin: "anonymous" }
      );
    }

    function updateColorObject(opt, hexColor) {
      if (!canvas) return;
      const activeObj = canvas.getActiveObject();
      if (activeObj && (activeObj instanceof fabric.IText || activeObj instanceof fabric.Text || activeObj instanceof fabric.Path)) {
        activeObj.set("fill", hexColor);
        canvas.renderAll();
      } else {
        canvas.getObjects().forEach((obj) => {
          if (obj instanceof fabric.IText || obj instanceof fabric.Text) {
            obj.set("fill", hexColor);
          }
        });
        canvas.renderAll();
      }
      updatePriceDisplay();
    }

    function updateDropdownObject(opt, choiceVal) {
      if (!canvas) return;
      let obj = findObjectByOptId(opt.id);
      if (obj) canvas.remove(obj);

      if (!choiceVal) {
        canvas.renderAll();
        updatePriceDisplay();
        return;
      }

      if (choiceVal.match(/^https?:\/\/.+\.(png|jpg|jpeg|svg|webp)($|\?)/i)) {
        updateImageObject(opt, choiceVal);
      } else {
        obj = new fabric.Text(choiceVal, {
          left: opt.printAreaX || (logicalWidth * 0.25),
          top: opt.printAreaY || (logicalHeight * 0.45),
          fontSize: 26,
          fill: "#0f172a",
          fontWeight: "bold",
        });
        obj.optId = opt.id;
        canvas.add(obj);
        canvas.renderAll();
        updatePriceDisplay();
      }
    }

    function showError(msg) {
      const el = document.getElementById("pxl-error-banner");
      el.textContent = msg;
      el.style.display = "block";
    }

    function hideError() {
      const el = document.getElementById("pxl-error-banner");
      el.style.display = "none";
    }

    function showSuccess(msg) {
      const el = document.getElementById("pxl-success-banner");
      el.textContent = msg;
      el.style.display = "block";
    }

    const addToCartBtn = document.getElementById("pxl-add-to-cart-btn");
    addToCartBtn.addEventListener("click", async function () {
      hideError();
      const missingRequired = customizableProduct.options.filter(
        (opt) => opt.required && !optionValues[opt.id]
      );

      if (missingRequired.length > 0) {
        showError(`Please complete all required options: ${missingRequired.map((o) => o.label).join(", ")}`);
        return;
      }

      addToCartBtn.disabled = true;
      const btnText = addToCartBtn.querySelector(".pxl-btn-text");
      const originalText = btnText.textContent;
      btnText.textContent = "Saving Design...";

      try {
        canvas.discardActiveObject();
        canvas.renderAll();

        const designData = JSON.stringify(canvas.toJSON());
        const previewDataUrl = canvas.toDataURL({
          format: "png",
          quality: 0.9,
          multiplier: 1.5,
        });

        const previewResponse = await fetch("/apps/customizer/preview", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            imageDataUrl: previewDataUrl,
            customizableProductId: customizableProduct.id,
          }),
        });

        const previewJson = await previewResponse.json();
        if (!previewResponse.ok || previewJson.error) {
          throw new Error(previewJson.error || "Failed to save preview image");
        }

        const previewImageUrl = previewJson.previewImageUrl;
        const designId = previewJson.previewId || `design_${Date.now()}`;

        await fetch("/apps/customizer/submission", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            designId,
            customizableProductId: customizableProduct.id,
            designData,
            previewImageUrl,
            customerNote: "Created with Interactive Studio",
          }),
        });

        btnText.textContent = "Adding to Cart...";
        const customProperties = {};
        let totalFee = 0;
        const currency = root.getAttribute("data-currency-symbol") || "$";

        customizableProduct.options.forEach((opt) => {
          const val = optionValues[opt.id];
          if (val && typeof val === "string") {
            const fee = Number(opt.config.priceAddon || opt.config.price || 0);
            if (fee > 0) totalFee += fee;

            let labelWithFee = opt.label;
            if (val.startsWith("data:image")) {
              customProperties[labelWithFee] = "Image Uploaded ✓";
            } else if (val.startsWith("http") || val.startsWith("/")) {
              customProperties[labelWithFee] = "Image Selected ✓";
            } else {
              customProperties[labelWithFee] = val;
            }
          }
        });

        if (totalFee > 0) {
          customProperties["Customization Fee"] = `+${currency}${totalFee.toFixed(2)}`;
        }
        customProperties["Design Preview"] = window.location.origin + previewImageUrl;
        customProperties["Design Ref"] = designId;
        customProperties["_customizer_design_id"] = designId;
        customProperties["_preview_image"] = previewImageUrl;

        const cartResponse = await fetch("/cart/add.js", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            items: [
              {
                id: parseInt(variantId, 10) || variantId,
                quantity: 1,
                properties: customProperties,
              },
            ],
          }),
        });

        if (!cartResponse.ok) {
          const cartErr = await cartResponse.json();
          throw new Error(cartErr.description || "Could not add product to cart");
        }

        showSuccess("Design saved and added to cart successfully!");
        btnText.textContent = "Added to Cart!";
        
        setTimeout(() => {
          if (typeof window.Shopify !== "undefined" && window.Shopify.onCartUpdate) {
            window.Shopify.onCartUpdate();
          }
          window.location.href = "/cart";
        }, 1100);
      } catch (err) {
        console.error("Add to cart error:", err);
        showError(err.message || "An error occurred while adding to cart.");
        addToCartBtn.disabled = false;
        btnText.textContent = originalText;
      }
    });

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initCustomizer);
    } else {
      initCustomizer();
    }
  })();
</script>

{% schema %}
{
  "name": "Product Customizer",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading Text",
      "default": "Personalize Your Product"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Add to Cart Button Label",
      "default": "Add Customized to Cart"
    }
  ]
}
{% endschema %}
